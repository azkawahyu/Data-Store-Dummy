generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  pending
  verified
  rejected
}

model activity_logs {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String?   @db.Uuid
  action      String?   @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model documents {
  id            String     @id @default(uuid()) @db.Uuid
  employee_id   String?    @db.Uuid
  document_type String     @db.VarChar(50)
  file_path     String
  file_name     String
  file_size     Int
  mime_type     String
  status        DocumentStatus @default(pending)
  uploaded_at   DateTime?  @default(now()) @db.Timestamp(6)
  verified_by   String?    @db.Uuid
  verified_at   DateTime?  @db.Timestamp(6)
  employees     employees? @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users?     @relation(fields: [verified_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model employees {
  id         String      @id @default(uuid()) @db.Uuid
  nip        String      @unique @db.VarChar(50)
  nama       String      @db.VarChar(150)
  jabatan    String?     @db.VarChar(100)
  unit       String?     @db.VarChar(100)
  status     String?     @db.VarChar(50)
  alamat     String?
  no_hp      String?     @db.VarChar(20)
  email      String?     @db.VarChar(150)
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  updated_at DateTime?   @updatedAt
  documents  documents[]
  users      users?
}

model roles {
  id    String  @id @default(uuid()) @db.Uuid
  name  String  @unique @db.VarChar(50)
  users users[]
}

model users {
  id            String          @id @default(uuid()) @db.Uuid
  employee_id   String?         @unique @db.Uuid
  role_id       String?         @db.Uuid
  username      String          @unique @db.VarChar(100)
  password_hash String
  nip           String?         @unique @db.VarChar(50)
  email         String?         @db.VarChar(150)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  activity_logs activity_logs[]
  documents     documents[]
  employees     employees?      @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles         roles?          @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
